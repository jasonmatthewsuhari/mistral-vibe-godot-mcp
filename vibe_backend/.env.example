PIXELLAB_API_KEY=your_pixellab_api_key_here

# Set one LLM key. LLM_PROVIDER auto-detects from whichever key is present.
# To force a specific provider: LLM_PROVIDER=openai | mistral | gemini
OPENAI_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Optional: explicitly select provider (openai | mistral | gemini)
LLM_PROVIDER=
